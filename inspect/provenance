#!/usr/bin/env bash
# provenance
# Browse repository history and create a new branch from a selected commit.

set -euo pipefail

HISTORY_LIMIT=1000
HISTORY_SCOPE="all"
ALLOW_DIRTY=false
BRANCH_SUFFIX="-provenance"
TEMP_HISTORY_FILE=""

RED='\033[1;31m'
GREEN='\033[1;32m'
YELLOW='\033[1;33m'
CYAN='\033[1;36m'
DIM='\033[2m'
RESET='\033[0m'

print_error() {
	printf "%bError:%b %s\n" "$RED" "$RESET" "$*" >&2
}

warn() {
	printf "%bWarning:%b %s\n" "$YELLOW" "$RESET" "$*" >&2
}

print_help() {
	cat <<'EOF'
provenance — browse Git history and branch from a selected commit

Usage:
  provenance [options]

Options:
  --all
      Show commits from all local and remote refs.
      This is the default.

  --current
      Show only commits reachable from the current branch.

  --limit <number>
      Maximum number of commits to load.
      Default: 1000

  --allow-dirty
      Permit branch creation with uncommitted changes.
      Changes may carry into the new branch.

  -h, --help
      Show this help.

Controls:
  Up/Down
      Move between commits.

  Enter
      Select a commit.

  Esc
      Cancel.

  Ctrl-P
      Toggle the commit preview.

Branch naming:
  The suffix "-provenance" is automatically added to branches
  created by this command.
EOF
}

cleanup() {
	if [[ -n "${TEMP_HISTORY_FILE:-}" ]]; then
		if ! rm -f -- "$TEMP_HISTORY_FILE"; then
			printf "%bWarning:%b Could not remove temporary file.\n" \
				"$YELLOW" "$RESET" >&2
		fi
	fi
}

trap cleanup EXIT

parse_arguments() {
	while (($#)); do
		case "$1" in
		--all)
			HISTORY_SCOPE="all"
			;;

		--current)
			HISTORY_SCOPE="current"
			;;

		--allow-dirty)
			ALLOW_DIRTY=true
			;;

		--limit)
			shift

			if (($# == 0)); then
				print_error "--limit requires a number."
				return 1
			fi

			if [[ ! "$1" =~ ^[1-9][0-9]*$ ]]; then
				print_error "Invalid history limit: $1"
				return 1
			fi

			HISTORY_LIMIT="$1"
			;;

		-h | --help)
			print_help
			return 2
			;;

		*)
			print_error "Unknown option: $1"
			return 1
			;;
		esac

		shift
	done
}

require_command() {
	local command_name
	command_name=$1

	if ! command -v "$command_name" >/dev/null 2>&1; then
		print_error "Required command not found: $command_name"
		return 1
	fi
}

enter_repository_root() {
	local repo_root

	if ! repo_root=$(git rev-parse --show-toplevel 2>/dev/null); then
		print_error "Not a Git repository."
		return 1
	fi

	if [[ -z "${repo_root//[[:space:]]/}" || ! -d "$repo_root" ]]; then
		print_error "Git returned an invalid repository root."
		return 1
	fi

	if ! cd -- "$repo_root"; then
		print_error "Could not enter repository root: $repo_root"
		return 1
	fi
}

get_repository_state() {
	local status_output

	if ! status_output=$(
		git status --porcelain --untracked-files=normal 2>/dev/null
	); then
		print_error "Could not inspect the working tree."
		return 1
	fi

	if [[ -n "$status_output" ]]; then
		printf "dirty"
	else
		printf "clean"
	fi
}

preview_commit() {
	local commit
	local parents
	local pr_url

	commit=$1
	parents=""
	pr_url=""

	if [[ ! "$commit" =~ ^[0-9a-fA-F]{7,64}$ ]]; then
		printf "Invalid commit identifier.\n" >&2
		return 1
	fi

	if ! parents=$(git show -s --format='%P' "$commit" 2>/dev/null); then
		printf "Unable to read commit.\n" >&2
		return 1
	fi

	if [[ "$parents" == *" "* ]] && command -v gh >/dev/null 2>&1; then
		if ! pr_url=$(
			gh api \
				-H "Accept: application/vnd.github+json" \
				"repos/{owner}/{repo}/commits/${commit}/pulls" \
				--jq '
					[
						.[] |
						select(
							.merged_at != null and
							.html_url != null
						)
					][0].html_url // empty
				' \
				2>/dev/null
		); then
			pr_url=""
		fi
	fi

	pr_url=${pr_url//$'\r'/}
	pr_url=${pr_url//$'\n'/}

	if [[ ! "$pr_url" =~ ^https://[^[:space:]]+$ ]]; then
		pr_url=""
	fi

	if [[ -z "$pr_url" ]]; then
		git --no-pager show \
			--color=always \
			--stat \
			--summary \
			--format=fuller \
			"$commit"
		return
	fi

	git --no-pager show \
		--color=always \
		--stat \
		--summary \
		--format=fuller \
		"$commit" |
		awk -v pr_url="$pr_url" '
			{
				print

				line = $0
				gsub(/\033\[[0-9;]*m/, "", line)

				if (!inserted && line ~ /^Merge:[[:space:]]/) {
					pr_number = pr_url
					sub(/^.*\/pull\//, "", pr_number)

					printf "\033[1;36mPull request:\033[0m "
					printf "\033]8;;%s\033\\", pr_url
					printf "\033[4;36mOpen pull request #%s\033[0m", pr_number
					printf "\033]8;;\033\\\n"

					inserted = 1
				}
			}
		'
}

export -f preview_commit

build_history() {
	local output_file
	local -a scope_args

	output_file=$1
	scope_args=()

	if [[ "$HISTORY_SCOPE" == "all" ]]; then
		scope_args+=(--all)
	else
		scope_args+=(HEAD)
	fi

	if ! git log \
		"${scope_args[@]}" \
		--graph \
		--decorate \
		--color=always \
		--date=short \
		--max-count="$HISTORY_LIMIT" \
		--pretty=format:'%x1f%H%x1f%C(auto)%h%Creset%x1f%ad%x1f%an%x1f%C(auto)%D%Creset%x1f%s' |
		awk -F '\037' '
			NF >= 7 {
				graph = $1
				full_hash = $2
				short_hash = $3
				date = $4
				author = $5
				refs = $6
				subject = $7

				gsub(/\t/, " ", subject)
				gsub(/\t/, " ", author)

				if (refs != "") {
					refs = "  " refs
				}

				printf "%s\t%s%s  %s  %-18s  %s%s\n",
					full_hash,
					graph,
					short_hash,
					date,
					author,
					subject,
					refs
			}
		' >"$output_file"; then
		print_error "Could not build repository history."
		return 1
	fi

	if [[ ! -s "$output_file" ]]; then
		print_error "No commits were found."
		return 1
	fi
}

select_commit() {
	local history_file
	local selection
	local selected_commit

	history_file=$1

	if ! selection=$(
		fzf \
			--ansi \
			--height=80% \
			--border=sharp \
			--layout=reverse \
			--delimiter=$'\t' \
			--with-nth=2.. \
			--nth=2.. \
			--info=inline \
			--prompt="Commit > " \
			--pointer="▌" \
			--header=$'provenance\nRepository history — Enter to branch · Esc to cancel · Ctrl-P to toggle preview' \
			--preview='bash -c '"'"'preview_commit "$1"'"'"' _ {1}' \
			--preview-window='right,55%,wrap' \
			--bind='ctrl-p:toggle-preview' \
			<"$history_file"
	); then
		return 1
	fi

	selected_commit=${selection%%$'\t'*}

	if [[ ! "$selected_commit" =~ ^[0-9a-fA-F]{7,64}$ ]]; then
		print_error "The selected commit identifier is invalid."
		return 1
	fi

	printf "%s" "$selected_commit"
}

print_commit_selection() {
	local commit
	local short_hash
	local date
	local author
	local subject
	local refs

	commit=$1

	if ! short_hash=$(git rev-parse --short "$commit" 2>/dev/null); then
		print_error "Could not read the selected commit hash."
		return 1
	fi

	if ! date=$(git show -s --date=short --format='%ad' "$commit" 2>/dev/null); then
		print_error "Could not read the selected commit date."
		return 1
	fi

	if ! author=$(git show -s --format='%an' "$commit" 2>/dev/null); then
		print_error "Could not read the selected commit author."
		return 1
	fi

	if ! subject=$(git show -s --format='%s' "$commit" 2>/dev/null); then
		print_error "Could not read the selected commit subject."
		return 1
	fi

	if ! refs=$(git show -s --format='%D' "$commit" 2>/dev/null); then
		print_error "Could not read the selected commit references."
		return 1
	fi

	printf "\n%bSelected commit%b\n" "$CYAN" "$RESET"
	printf "  Hash:    %s\n" "$short_hash"
	printf "  Date:    %s\n" "$date"
	printf "  Author:  %s\n" "$author"
	printf "  Subject: %s\n" "$subject"

	if [[ -n "$refs" ]]; then
		printf "  Refs:    %s\n" "$refs"
	fi
}

confirm_branch_creation() {
	local decision

	while true; do
		printf "\n%bCreate a new branch from this commit?%b ([y]/n): " \
			"$YELLOW" "$RESET"

		if ! IFS= read -r decision; then
			printf "\n" >&2
			return 1
		fi

		case "${decision:-y}" in
		y | Y | yes | YES | Yes)
			return
			;;

		n | N | no | NO | No)
			printf "%bNo branch was created.%b\n" "$DIM" "$RESET"
			return 1
			;;

		*)
			printf "%bInvalid response.%b Enter y, n, or press Enter for yes.\n" \
				"$RED" "$RESET" >&2
			;;
		esac
	done
}

slugify() {
	local value
	local slug

	value=$1

	if ! slug=$(
		printf "%s" "$value" |
			tr '[:upper:]' '[:lower:]' |
			sed -E \
				-e 's/[^a-z0-9._-]+/-/g' \
				-e 's/^-+//' \
				-e 's/-+$//' \
				-e 's/-+/-/g'
	); then
		print_error "Could not create a branch-name suggestion."
		return 1
	fi

	printf "%.48s" "$slug"
}

suggest_branch_base() {
	local commit
	local subject
	local slug
	local short_hash

	commit=$1

	if ! subject=$(git show -s --format='%s' "$commit" 2>/dev/null); then
		print_error "Could not read the commit subject."
		return 1
	fi

	if ! slug=$(slugify "$subject"); then
		return 1
	fi

	if ! short_hash=$(git rev-parse --short "$commit" 2>/dev/null); then
		print_error "Could not shorten the commit hash."
		return 1
	fi

	if [[ -n "$slug" ]]; then
		printf "%s" "$slug"
	else
		printf "historical-%s" "$short_hash"
	fi
}

append_branch_suffix() {
	local branch_base
	branch_base=$1

	if [[ "$branch_base" == *"$BRANCH_SUFFIX" ]]; then
		printf "%s" "$branch_base"
	else
		printf "%s%s" "$branch_base" "$BRANCH_SUFFIX"
	fi
}

prompt_for_branch_name() {
	local commit
	local suggested_base
	local branch_base
	local branch_name

	commit=$1

	if ! suggested_base=$(suggest_branch_base "$commit"); then
		return 1
	fi

	while true; do
		printf "\n%bEnter a name for the new branch%b [%s]: " \
			"$CYAN" "$RESET" "$suggested_base" >&2

		if ! IFS= read -r branch_base; then
			printf "\n" >&2
			return 1
		fi

		branch_base=${branch_base:-$suggested_base}

		case "$branch_base" in
		q | quit | exit)
			return 1
			;;
		esac

		if ! branch_name=$(append_branch_suffix "$branch_base"); then
			print_error "Could not construct the branch name."
			continue
		fi

		if ! git check-ref-format --branch "$branch_name" >/dev/null 2>&1; then
			printf "%bInvalid branch name:%b %s\n" \
				"$RED" "$RESET" "$branch_name" >&2
			continue
		fi

		if git show-ref --verify --quiet "refs/heads/$branch_name"; then
			printf "%bBranch already exists:%b %s\n" \
				"$YELLOW" "$RESET" "$branch_name" >&2
			continue
		fi

		printf "\n%bBranch to create:%b %s\n" \
			"$CYAN" "$RESET" "$branch_name" >&2

		printf "%s" "$branch_name"
		return
	done
}

create_branch() {
	local branch_name
	local commit
	local repository_state
	local short_hash
	local subject

	branch_name=$1
	commit=$2

	if ! repository_state=$(get_repository_state); then
		return 1
	fi

	if [[ "$repository_state" == "dirty" ]]; then
		if [[ "$ALLOW_DIRTY" != true ]]; then
			printf "\n%bBranch creation blocked:%b the working tree contains uncommitted changes.\n" \
				"$RED" "$RESET"
			printf "Commit, stash, or discard the changes before continuing.\n"
			printf "Use %bprovenance --allow-dirty%b to override this protection.\n" \
				"$CYAN" "$RESET"
			return 1
		fi

		warn "Uncommitted changes may carry into the new branch."
	fi

	printf "\n%bCreating branch:%b %s\n" \
		"$CYAN" "$RESET" "$branch_name"

	if ! git switch -c "$branch_name" "$commit"; then
		printf "\n%bBranch creation failed.%b\n" "$RED" "$RESET"
		return 1
	fi

	if ! short_hash=$(git rev-parse --short HEAD 2>/dev/null); then
		short_hash="$commit"
	fi

	if ! subject=$(git show -s --format='%s' HEAD 2>/dev/null); then
		subject="Unknown"
	fi

	printf "\n%bBranch created successfully.%b\n" "$GREEN" "$RESET"
	printf "  Branch:  %s\n" "$branch_name"
	printf "  Commit:  %s\n" "$short_hash"
	printf "  Subject: %s\n" "$subject"
}

main() {
	local parse_status
	local selected_commit
	local branch_name

	if parse_arguments "$@"; then
		parse_status=0
	else
		parse_status=$?

		if ((parse_status == 2)); then
			return
		fi

		return 1
	fi

	if ! require_command git; then
		return 1
	fi

	if ! require_command fzf; then
		return 1
	fi

	if ! require_command awk; then
		return 1
	fi

	if ! require_command sed; then
		return 1
	fi

	if ! require_command tr; then
		return 1
	fi

	if ! require_command mktemp; then
		return 1
	fi

	if ! enter_repository_root; then
		return 1
	fi

	if ! TEMP_HISTORY_FILE=$(mktemp); then
		print_error "Could not create a temporary history file."
		return 1
	fi

	if [[ -z "$TEMP_HISTORY_FILE" || ! -f "$TEMP_HISTORY_FILE" ]]; then
		print_error "The temporary history file is invalid."
		return 1
	fi

	if ! build_history "$TEMP_HISTORY_FILE"; then
		return 1
	fi

	if ! selected_commit=$(select_commit "$TEMP_HISTORY_FILE"); then
		printf "%bSelection canceled.%b\n" "$DIM" "$RESET"
		return
	fi

	if ! git cat-file -e "${selected_commit}^{commit}" 2>/dev/null; then
		print_error "The selected object is not a valid commit."
		return 1
	fi

	if ! print_commit_selection "$selected_commit"; then
		return 1
	fi

	if ! confirm_branch_creation; then
		return
	fi

	if ! branch_name=$(prompt_for_branch_name "$selected_commit"); then
		printf "%bBranch creation canceled.%b\n" "$DIM" "$RESET"
		return
	fi

	if ! create_branch "$branch_name" "$selected_commit"; then
		return 1
	fi
}

main "$@"